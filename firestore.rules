rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, 'admin' or 'user')
    //   - preferences: map (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: generations
    // Document ID: {generationId}
    // Fields:
    //   - userId: string (required)
    //   - niche: string (required)
    //   - activityType: string (required)
    //   - targetAudience: string (optional)
    //   - results: map (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ahmed.morgan2009@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidGeneration(data) {
      return data.keys().hasAll(['userId', 'niche', 'activityType', 'results', 'createdAt']) &&
             data.userId is string &&
             data.niche is string &&
             data.activityType is string &&
             data.results is map &&
             data.createdAt is timestamp;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'type', 'content', 'niche', 'createdAt']) &&
             data.userId is string &&
             data.type in ['post', 'video', 'caption'] &&
             data.content is string &&
             data.niche is string &&
             data.createdAt is timestamp;
    }

    function isValidScheduledPost(data) {
      return data.keys().hasAll(['userId', 'content', 'platform', 'scheduledAt', 'status', 'createdAt']) &&
             data.userId is string &&
             data.content is string &&
             data.platform is string &&
             data.scheduledAt is timestamp &&
             data.status in ['pending', 'published', 'failed'] &&
             data.createdAt is timestamp;
    }

    function isValidABTest(data) {
      return data.keys().hasAll(['userId', 'niche', 'variationA', 'variationB', 'status', 'createdAt']) &&
             data.userId is string &&
             data.niche is string &&
             data.variationA is map &&
             data.variationB is map &&
             data.status in ['active', 'completed'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile, unless they are admin
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but only admin can create admin roles
      allow create: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    isOwner(userId) && 
                    (request.resource.data.role == 'user' || isAdmin());
      
      // Users can update their own profile, but cannot change their role unless admin
      // Admins can update any user profile
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    (
                      (isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin())) ||
                      isAdmin()
                    );
      
      // Only admin can delete users
      allow delete: if isAdmin();
    }

    match /generations/{generationId} {
      // Users can read their own generations, admin can read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can create generations for themselves
      allow create: if isAuthenticated() && 
                    isValidGeneration(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own generations, admin can delete all
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Generations are immutable
      allow update: if false;
    }

    match /favorites/{favoriteId} {
      // Users can only read their own favorites
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create favorites for themselves
      allow create: if isAuthenticated() && 
                    isValidFavorite(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own favorites
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Favorites are immutable
      allow update: if false;
    }

    match /scheduled_posts/{postId} {
      // Users can only read their own scheduled posts
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create scheduled posts for themselves
      allow create: if isAuthenticated() && 
                    isValidScheduledPost(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own scheduled posts
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Only admin can update status
      allow update: if isAdmin() && 
                    isValidScheduledPost(request.resource.data) && 
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.content == resource.data.content &&
                    request.resource.data.platform == resource.data.platform &&
                    request.resource.data.scheduledAt == resource.data.scheduledAt &&
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    match /ab_tests/{testId} {
      // Users can only read their own A/B tests
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create A/B tests for themselves
      allow create: if isAuthenticated() && 
                    isValidABTest(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      
      // Users can update their own A/B tests (for metrics)
      allow update: if isAuthenticated() && 
                    isValidABTest(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
      
      // Users can delete their own A/B tests
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
